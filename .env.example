# Supabase — Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...   # anon/public key — safe for client
SUPABASE_SERVICE_ROLE_KEY=                                 # secret — csak szerveren, soha gitbe!

# Token encryption (AES-256-GCM) — generálás:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=your-64-char-hex-string

# Resend — resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key

NEXT_PUBLIC_APP_URL=http://localhost:3001
