{
  "manifest_version": 3,
  "name": "FlowSpace",
  "version": "0.1.0",
  "description": "Tiling workspace manager for your browser — organize multiple websites side-by-side.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "FlowSpace"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "externally_connectable": {
    "matches": ["http://localhost:3001/*", "https://app.flowspace.io/*"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "flowspace@flowspace.io",
      "strict_min_version": "128.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3001/auth/extension*",
        "https://app.flowspace.io/auth/extension*"
      ],
      "js": ["src/content/auth-relay.ts"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content/sidebar.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
