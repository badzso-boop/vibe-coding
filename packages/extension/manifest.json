{
  "manifest_version": 3,
  "name": "FlowSpace",
  "version": "0.1.0",
  "description": "Tiling workspace manager for your browser — organize multiple websites side-by-side.",
  "permissions": [
    "storage",
    "tabs",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "FlowSpace"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:3001/*",
      "https://app.flowspace.io/*"
    ]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_iframe",
        "enabled": true,
        "path": "rules/iframe.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["src/content/sidebar.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
